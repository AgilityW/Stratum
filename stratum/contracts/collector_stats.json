{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CollectorStats",
  "description": "Per-run collector sidecar written beside raw.json.",
  "type": "object",
  "required": ["domain", "date", "total_results", "sources"],
  "properties": {
    "domain": {"type": "string"},
    "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "total_results": {"type": "integer", "minimum": 0},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "access", "status", "hits", "selected", "duration_ms", "dated"],
        "properties": {
          "source": {"type": "string"},
          "access": {
            "type": "string",
            "enum": ["direct_fetch", "rss", "browser", "unknown"]
          },
          "status": {
            "type": "string",
            "enum": ["ok", "empty", "error", "unsupported", "skipped"]
          },
          "hits": {"type": "integer", "minimum": 0},
          "selected": {"type": "integer", "minimum": 0},
          "duration_ms": {"type": "number", "minimum": 0},
          "locale": {"type": "string"},
          "category": {"type": "string"},
          "dated": {"type": "integer", "minimum": 0},
          "error": {"type": "string"}
        }
      }
    }
  }
}
