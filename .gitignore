data/
health-data/
/storage/
*.ndjson
*.jsonl

# Cache / temp
*.pyc
__pycache__/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# Runtime config (generated at runtime)
data/value-chain/runtime-config.json
