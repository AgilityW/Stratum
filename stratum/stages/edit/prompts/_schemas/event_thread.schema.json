{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "event_thread",
  "type": "object",
  "required": ["thread_id", "title", "status", "priority"],
  "additionalProperties": false,
  "properties": {
    "thread_id": {
      "type": "string",
      "pattern": "^et-[A-Za-z0-9][A-Za-z0-9_-]*$",
      "description": "事件线程 ID。已有 thread 使用上下文 ID；新 thread 可由 Edit 规范化为 et-{domain}-{date}-{hash}"
    },
    "id": {
      "type": "string",
      "pattern": "^et-[A-Za-z0-9][A-Za-z0-9_-]*$",
      "description": "thread_id 的兼容别名"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160,
      "description": "事件线程标题"
    },
    "label": {
      "type": "string",
      "maxLength": 160,
      "description": "旧格式标题别名"
    },
    "canonical_question": {
      "type": "string",
      "maxLength": 300,
      "description": "该线程追踪的核心问题"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "线程说明"
    },
    "status": {
      "type": "string",
      "enum": ["emerging", "active", "cooling", "dormant", "resolved", "archived"],
      "description": "事件生命周期状态"
    },
    "priority": {
      "oneOf": [
        {"type": "string", "enum": ["high", "medium", "low", "P1", "P2", "P3", "urgent"]},
        {"type": "integer", "minimum": 1, "maximum": 3}
      ],
      "description": "事件优先级，可用标签或 DB rank"
    },
    "entity_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "description": "相关实体 ID"
    },
    "term_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "description": "相关主题/技术 ID"
    },
    "watch_signals": {
      "type": "array",
      "items": {"type": "string", "minLength": 3},
      "description": "后续 Search follow-up 短语"
    },
    "open_questions": {
      "type": "array",
      "items": {"type": "string", "minLength": 3},
      "description": "仍需验证的问题"
    },
    "close_conditions": {
      "type": "array",
      "items": {"type": "string", "minLength": 3},
      "description": "线程可关闭的条件"
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "创建日期"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "最近更新日期"
    }
  }
}
