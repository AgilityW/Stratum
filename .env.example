# Stratum — API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# .env is gitignored — never commit your real keys.

# Bocha AI Search (Chinese/Asian markets) — https://api.bocha.cn
BOCHA_API_KEY=your-bocha-key-here

# Tavily Search (English/Global) — https://tavily.com
TAVILY_API_KEY=your-tavily-key-here
