{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RawSearchStats",
  "description": "Search execution and curation diagnostics written beside raw.json.",
  "type": "object",
  "required": ["date", "total_raw", "total_curated", "by_engine", "by_locale", "by_source_type", "diagnostics", "queries"],
  "properties": {
    "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "total_raw": {"type": "integer", "minimum": 0},
    "total_curated": {"type": "integer", "minimum": 0},
    "by_engine": {"$ref": "#/definitions/countMap"},
    "by_locale": {"$ref": "#/definitions/countMap"},
    "by_source_type": {"$ref": "#/definitions/countMap"},
    "diagnostics": {
      "type": "object",
      "required": [
        "raw_by_locale",
        "curated_by_locale",
        "raw_by_source_type",
        "curated_by_source_type",
        "raw_by_dimension",
        "curated_by_dimension",
        "dimension_coverage",
        "locale_coverage",
        "source_type_gaps",
        "domain_filter_coverage",
        "top_source_domains",
        "low_yield_queries"
      ],
      "properties": {
        "raw_by_locale": {"$ref": "#/definitions/countMap"},
        "curated_by_locale": {"$ref": "#/definitions/countMap"},
        "raw_by_source_type": {"$ref": "#/definitions/countMap"},
        "curated_by_source_type": {"$ref": "#/definitions/countMap"},
        "raw_by_dimension": {"$ref": "#/definitions/countMap"},
        "curated_by_dimension": {"$ref": "#/definitions/countMap"},
        "dimension_coverage": {
          "type": "array",
          "items": {"$ref": "#/definitions/dimensionCoverage"}
        },
        "locale_coverage": {
          "type": "array",
          "items": {"$ref": "#/definitions/localeCoverage"}
        },
        "source_type_gaps": {
          "type": "array",
          "items": {"$ref": "#/definitions/sourceTypeGap"}
        },
        "domain_filter_coverage": {
          "type": "array",
          "items": {"$ref": "#/definitions/domainFilterCoverage"}
        },
        "top_source_domains": {
          "type": "array",
          "items": {"$ref": "#/definitions/topSourceDomain"}
        },
        "low_yield_queries": {
          "type": "array",
          "items": {"$ref": "#/definitions/queryStats"}
        }
      }
    },
    "queries": {
      "type": "array",
      "items": {"$ref": "#/definitions/queryStats"}
    }
  },
  "definitions": {
    "countMap": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "queryStats": {
      "type": "object",
      "required": ["query_id", "engine_used", "status", "results_count"],
      "properties": {
        "query_id": {"type": "string"},
        "engine_used": {"type": "string"},
        "status": {
          "type": "string",
          "enum": ["success", "fallback", "failed", "rate_limited", "no_results", "skipped_covered"]
        },
        "results_count": {"type": "integer", "minimum": 0},
        "locale": {"type": "string"},
        "intent": {"type": "string"},
        "dimension": {"type": "string"},
        "query_text": {"type": "string"},
        "include_domains": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "retries": {"type": "integer", "minimum": 0},
        "latency_ms": {"type": "number", "minimum": 0},
        "error": {"type": ["string", "null"]}
      }
    },
    "dimensionCoverage": {
      "type": "object",
      "required": ["dimension", "queries", "raw", "curated"],
      "properties": {
        "dimension": {"type": "string"},
        "queries": {"type": "integer", "minimum": 0},
        "raw": {"type": "integer", "minimum": 0},
        "curated": {"type": "integer", "minimum": 0}
      }
    },
    "localeCoverage": {
      "type": "object",
      "required": ["locale", "queries", "raw", "curated"],
      "properties": {
        "locale": {"type": "string"},
        "queries": {"type": "integer", "minimum": 0},
        "raw": {"type": "integer", "minimum": 0},
        "curated": {"type": "integer", "minimum": 0}
      }
    },
    "sourceTypeGap": {
      "type": "object",
      "required": ["source_type", "minimum", "raw_available", "curated", "shortfall"],
      "properties": {
        "source_type": {"type": "string"},
        "minimum": {"type": "integer", "minimum": 0},
        "raw_available": {"type": "integer", "minimum": 0},
        "curated": {"type": "integer", "minimum": 0},
        "shortfall": {"type": "integer", "minimum": 0}
      }
    },
    "domainFilterCoverage": {
      "type": "object",
      "required": ["include_domain", "queries", "failed_queries", "raw", "curated"],
      "properties": {
        "include_domain": {"type": "string"},
        "queries": {"type": "integer", "minimum": 0},
        "failed_queries": {"type": "integer", "minimum": 0},
        "raw": {"type": "integer", "minimum": 0},
        "curated": {"type": "integer", "minimum": 0}
      }
    },
    "topSourceDomain": {
      "type": "object",
      "required": ["domain", "raw", "curated"],
      "properties": {
        "domain": {"type": "string"},
        "raw": {"type": "integer", "minimum": 0},
        "curated": {"type": "integer", "minimum": 0}
      }
    }
  }
}
